html
    head
        title #{chat.name}
        link(rel="stylesheet", href="/css/styles.css")
    body
        h1 #{chat.name}
        a(href='/') Tilbage til forsiden

        ul
            each message in chat.messages
                li
                    - const user = users.find(u => u.id === message.userId)
                    | #{message.text} - #{user ? user.username : 'Ukendt'}

        form(action="/chats/" + chat.id + "/messages", method="post")
            input(type="text", name="text", placeholder="skriv en besked")
            button(type="submit") Send 