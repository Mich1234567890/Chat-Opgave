html
    head 
        title forside
        link(rel="stylesheet", href="/css/styles.css")
        script(src="/js/submit.js" defer) 
    body 
        p Tillykke - du er nu logget ind med #{user.username}
        p her kan du 
            a(href='/users/logout') logge ud

        h2 Chats
        ul
            each chat in chats
                li 
                    a(href='/chats/' + chat.id + '/view') #{chat.name}

        if user.level >= 2
            h3 Opret chat
            form(action="/chats", method="post")
                input(type="text", name="name", placeholder="chat navn")
                button(type="submit") Opret chat

        h2 Opret bruger
        form(action="/users/adduser", method="post")
            input(type="text", name="username", id="username", placeholder="brugernavn")
            input(type="password", name="password", id="password", placeholder="kodeord")
            input(type="number", name="level", id="level", placeholder="brugerniveau (1-3)" min="1" max="3")
            button(type="submit", id="createuserbtn")
                strong Opret 
                | bruger
        div